{
  "manifest_version": 3,
  "name": "SAM Link Copier",
  "short_name": "SAM Copier",
  "version": "1.0.0",
  "description": "Instantly copy SAM.gov opportunity links from ezgovopps.com with a single click.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://ezgovopps.com/*"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Copy SAM.gov Link"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
